# =============================================================
# Department of Anatomy Portal — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
#   Neon:        postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#   Supabase DB: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Local:       postgresql://postgres:password@localhost:5432/anatomy_portal
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "false" to disable SSL (e.g., local development without SSL)
# Leave unset or "true" for all cloud providers
DATABASE_SSL=true

# JWT secret — use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here-min-32-chars

# Bootstrap admin email — the first account created with this email
# automatically gets admin role. Set before running the app for the first time.
ADMIN_EMAIL=admin@yourdomain.com
