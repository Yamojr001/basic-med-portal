# =============================================================
#  Department of Anatomy Portal — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to git — it is listed in .gitignore.
# =============================================================

# ─────────────────────────────────────────
#  DATABASE
# ─────────────────────────────────────────

# Full PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Recommended providers:
#   Neon (best for Vercel, free tier):
#     postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#
#   Supabase (PostgreSQL only — we do NOT use the Supabase SDK):
#     postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#
#   Railway PostgreSQL (internal):
#     postgresql://postgres:pass@containers-us-west-xxx.railway.app:5432/railway
#
#   Local development:
#     postgresql://postgres:password@localhost:5432/anatomy_portal
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SSL mode for the database connection.
# Set to "false" for local development or Railway internal databases.
# Set to "true" for all cloud providers (Neon, Supabase, Render, etc.).
DATABASE_SSL=true

# ─────────────────────────────────────────
#  AUTHENTICATION
# ─────────────────────────────────────────

# Long random string used to sign JWT tokens (minimum 32 characters).
# IMPORTANT: Keep this secret — anyone with this value can forge auth tokens.
#
# Generate a secure value:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-very-long-random-secret-min-32-chars

# The email address for the first admin account.
# When a user signs up with exactly this email, they automatically
# receive the "admin" role. Set this BEFORE running the app for the first time.
#
# If you already have a user and need to promote them manually:
#   UPDATE users SET role = 'admin' WHERE email = 'your@email.com';
ADMIN_EMAIL=admin@yourdomain.com

# ─────────────────────────────────────────
#  SERVER (optional)
# ─────────────────────────────────────────

# Deployment target for Nitro. Controlled here or passed as an env var at build time.
#   "vercel"      → Vercel (default if unset)
#   "node-server" → Railway, Render, VPS — run with: node .output/server/index.mjs
#   "netlify"     → Netlify
#
# Typically you set this via the build command (npm run build:node) rather than .env.
# NITRO_PRESET=vercel

# Server port (development only — production port is managed by the platform).
# PORT=5000

# Node environment. Set to "production" on all hosted platforms.
NODE_ENV=production

# ─────────────────────────────────────────
#  QUICK SETUP CHECKLIST
# ─────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in DATABASE_URL, DATABASE_SSL, JWT_SECRET, ADMIN_EMAIL
# 3. Run the schema migration:  node scripts/migrate.mjs
# 4. Start the dev server:  npm run dev
# 5. Open http://localhost:5000/auth → sign up with ADMIN_EMAIL
# 6. Access admin dashboard at http://localhost:5000/admin
#
# Full deployment guide: see DEPLOYMENT.md
# =============================================================
